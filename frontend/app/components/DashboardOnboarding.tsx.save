"use client"

import { useEffect, useState } from "react"

type Lang = "ru" | "uz"

const text = {
  ru: {
    welcomeTitle: "Добро пожаловать в MarketCard AI",
    welcomeText: "Оплата временно доступна только через Payme. Для работы с сервисом активируйте любой из 3 тарифов.",
    payme: "Payme",
    chooseTariff: "Выберите тариф",
    close: "Понятно",
    photo: "Загрузите фото товара хорошего качества. От качества фото напрямую зависит результат генерации.",
    title: "Опишите товар максимально подробно: название, марка, модель, количество штук, характеристики.",
    variants: "Выберите количество изображений за одну генерацию. Start: только 1. Business: 1 или 3. Premium: 1, 3 или 5.",
    fix: "Первые 3 исправления на каждую отдельную фотографию бесплатные. С 4-го исправления списывается 1 генерация.",
    economy: "Юнит-экономика помогает посчитать себестоимость, комиссии, логистику и прибыль, чтобы не уйти в ноль.",
    seo: "После генерации карточки перейдите в SEO / Описание — текст будет готов автоматически на RU и UZ.",
    audit: "Оценка карточки показывает слабые места изображения и помогает понять, что улучшить перед публикацией.",
    analytics: "Аналитика товара показывает конкуренцию, цены, спрос и помогает понять, стоит ли заходить в нишу.",
    auditsBuy: "Аудиты нужны для оценки карточек, аналитики товара и ABC-анализа. Их можно докупить отдельно.",
    congrats: "Поздравляем с приобретением тарифа",
  },
  uz: {
    welcomeTitle: "MarketCard AI platformasiga xush kelibsiz",
    welcomeText: "To‘lov vaqtincha faqat Payme orqali mavjud. Xizmatdan foydalanish uchun 3 ta tarifdan birini faollashtiring.",
    payme: "Payme",
    chooseTariff: "Tarifni tanlang",
    close: "Tushunarli",
    photo: "Mahsulot rasmini sifatli yuklang. Rasm sifati generatsiya natijasiga bevosita ta’sir qiladi.",
    title: "Mahsulot nomini batafsil yozing: nomi, brendi, modeli, soni va asosiy xususiyatlari.",
    variants: "Bitta generatsiyada nechta rasm yaratishni tanlang. Start: faqat 1. Business: 1 yoki 3. Premium: 1, 3 yoki 5.",
    fix: "Har bir alohida rasm uchun dastlabki 3 ta tuzatish bepul. 4-tuzatishdan boshlab 1 generatsiya yechiladi.",
    economy: "Unit-ekonomika tannarx, komissiya, logistika va foydani hisoblab, zarar bilan sotmaslikka yordam beradi.",
    seo: "Kartochka yaratilgandan so‘ng SEO / Tavsif bo‘limiga o‘ting — matn RU va UZ tillarida avtomatik tayyor bo‘ladi.",
    audit: "Kartochka baholash rasmning zaif joylarini ko‘rsatadi va nimalarni yaxshilash kerakligini tushuntiradi.",
    analytics: "Mahsulot analitikasi raqobat, narxlar va talabni ko‘rsatib, nishaga kirish kerak yoki yo‘qligini baholaydi.",
    auditsBuy: "Auditlar kartochka baholash, mahsulot analitikasi va ABC-tahlil uchun kerak. Ularni alohida sotib olish mumkin.",
    congrats: "Tarif xaridingiz bilan tabriklaymiz",
  },
}

export default function DashboardOnboarding() {
  const [lang, setLang] = useState<Lang>("ru")
  const [welcomeOpen, setWelcomeOpen] = useState(false)
  const [tip, setTip] = useState<string | null>(null)
  const [confetti, setConfetti] = useState(false)

  const t = text[lang]

  useEffect(() => {
    if (!localStorage.getItem("marketcard_welcome_v2_seen")) setWelcomeOpen(true)

    const style = document.createElement("style")
    style.innerHTML = `
      @keyframes marketcardPulseTariff {
        0% { transform: scale(1); box-shadow: 0 0 0 rgba(34,197,94,0.0); }
        50% { transform: scale(1.02); box-shadow: 0 0 14px rgba(34,197,94,0.45); }
        100% { transform: scale(1); box-shadow: 0 0 0 rgba(34,197,94,0.0); }
      }
      .marketcard-tariff-pulse { animation: marketcardPulseTariff 1.15s infinite; }
      .marketcard-tip-bubble {
        position: fixed; z-index: 9998; right: 24px; bottom: 24px;
        max-width: 430px; padding: 18px 20px; border-radius: 22px;
        background: linear-gradient(180deg,#0f172a,#020617);
        color: white; border: 1px solid rgba(34,211,238,0.35);
        box-shadow: 0 24px 70px rgba(0,0,0,0.55);
        font-weight: 800; line-height: 1.45;
      }
      .marketcard-confetti-piece {
        position: fixed; top: -20px; width: 10px; height: 18px; z-index: 9997;
        animation: marketcardConfetti 2.3s linear forwards;
      }
      @keyframes marketcardConfetti {
        to { transform: translateY(110vh) rotate(720deg); opacity: 0; }
      }
     `
    document.head.appendChild(style)

    const handleClick = (event: MouseEvent) => {
      const target = event.target as HTMLElement | null
      const el = target?.closest("button, div, input, label") as HTMLElement | null
      const html = (el?.textContent || target?.getAttribute?.("placeholder") || "").trim()

      if (!html) return

      if (html.includes("Выберите тариф") || html.includes("Tarifni tanlang")) {
        localStorage.setItem("marketcard_tariff_clicked", "1")
        document.querySelectorAll(".marketcard-tariff-pulse").forEach((x) => x.classList.remove("marketcard-tariff-pulse"))
      }

      if (html.includes("Генератор карточек")) setTip(t.photo)
      else if (html.includes("Загрузить фото") || html.includes("Файл не выбран")) setTip(t.photo)
      else if (html.includes("Название товара") || html.includes("Насос") || html.includes("Mahsulot nomi")) setTip(t.title)
      else if (html.includes("Количество вариантов")  html === "1"  html === "3" || html === "5") setTip(t.variants)
      else if (html.includes("Исправление изображения") || html.includes("Исправить ошибки")) setTip(t.fix)
      else if (html.includes("Юнит-экономика")) setTip(t.economy)
      else if (html.includes("SEO") || html.includes("Описание")) setTip(t.seo)
      else if (html.includes("Оценка карточки")) setTip(t.auit)
      else if (html.inclues("Аналитика товара")) setTip(t.analytics)
      else if (html.includes("ABC анализ")) setTip("ABC-анализ оценивает товар по ссылке: класс A/B/C, риски, спрос, конкуренцию и рекомендации по запуску. / ABC tahlil havola orqali mahsulotni baholaydi: A/B/C sinfi, xavflar, talab, raqobat va tavsiyalar.")
      else if (html.includes("Поиск и закуп")) setTip("Поиск и закуп товара помогает найти перспективные товары для продажи и понять, что лучше закупать. / Mahsulot qidirish va xarid qilish sotishga mos mahsulotlarni topishga yordam beradi.")
      else if (html.includes("Дефицит товаров")) setTip("Дефицит товаров показывает, где спрос есть, а предложений мало — это помогает находить ниши для продаж. / Tovar defitsiti talab bor, lekin taklif kam bo‘lgan yo‘nalishlarni ko‘rsatadi.")
      else if (html.includes("Купить 10 аудитов") || html.includes("Купить 30 аудитов") || html.includes("Оценок карточек")) setTip(t.auditsBuy)
    }

    const scan = () => {
      document.querySelectorAll("button").forEach((el) => {
        const html = (el.textContent || "").trim()
        if (html.includes("Выберите тариф") || html.includes("Tarifni tanlang")) {
          if (!localStorage.getItem("marketcard_tariff_clicked")) {
            el.classList.add("marketcard-tariff-pulse")
          }
        }
      })
    }

    document.addEventListener("click", handleClick)
    setTimeout(scan, 700)
    const id = setInterval(scan, 3000)

    const currentTariff = document.body.innerText.match(/Тариф:\s*(Start|Business|Premium)/)?.[1]
    const oldTariff = localStorage.getItem("marketcard_last_tariff")

    if (currentTariff && currentTariff !== oldTariff) {
      localStorage.setItem("marketcard_last_tariff", currentTariff)
      setTip(`${t.congrats}: ${currentTariff}`)
      setConfetti(true)
      setTimeout(() => setConfetti(false), 2500)
    }

    return () => {
      clearInterval(id)
      document.removeEventListener("click", handleClick)
      style.remove()
    }
  }, [lang])

  const closeWelcome = () => {
    localStorage.setItem("marketcard_welcome_v2_seen", "1")
    setWelcomeOpen(false)
  }

  return (
    <>
      {confetti &&
        Array.from({ length: 60 }).map((_, i) => (
          <span
            key={i}
            className="marketcard-confetti-piece"
            style={{
              left: `${Math.random() * 100}vw`,
              background: ["#22c55e", "#06b6d4", "#f59e0b", "#a855f7"][i % 4],
              animationDelay: `${Math.random() * 0.7}s`,
            }}
          />
        ))}

      {welcomeOpen && (
        <div style={{ position: "fixed", inset: 0, zIndex: 9999, background: "rgba(0,0,0,.72)", display: "flex", alignItems: "center", justifyContent: "center", padding: 20 }}>
          <div style={{ maxWidth: 520, width: "100%", borderRadius: 28, background: "linear-gradient(180deg,#0f172a,#020617)", color: "#fff", padding: 28, border: "1px solid rgba(34,211,238,.35)", boxShadow: "0 30px 90px rgba(0,0,0,.55)" }}>
            <div style={{ display: "flex", gap: 8, marginBottom: 16 }}>
              <button onClick={() => setLang("ru")} style={{ padding: "8px 14px", borderRadius: 999, border: "none", background: lang === "ru" ? "#22c55e" : "#1e293b", color: "#fff", fontWeight: 900 }}>RU</button>
              <button onClick={() => setLang("uz")} style={{ padding: "8px 14px", borderRadius: 999, border: "none", background: lang === "uz" ? "#22c55e" : "#1e293b", color: "#fff", fontWeight: 900 }}>UZ</button>
            </div>

            <h2 style={{ fontSize: 30, margin: "0 0 12px", fontWeight: 950 }}>
              {t.welcomeTitle}
            </h2>

            <p style={{ color: "#cbd5e1", fontSize: 17, lineHeight: 1.6 }}>
              {t.welcomeText}
            </p>

            <div style={{ marginTop: 16, padding: 14, borderRadius: 16, background: "rgba(6,182,212,.12)", border: "1px solid rgba(6,182,212,.35)", fontWeight: 950 }}>
              💳 {t.payme}
            </div>

            <button
              onClick={closeWelcome}
              style={{
                marginTop: 22,
                width: "100%",
                padding: 15,
                borderRadius: 16,
                border: "none",
                background: "linear-gradient(135deg,#22c55e,#06b6d4)",
                color: "#fff",
                fontWeight: 950,
                fontSize: 16,
                cursor: "pointer",
              }}
            >
              {t.close}
            </button>
          </div>
        </div>
      )}

      {tip && (
        <div className="marketcard-tip-bubble" onClick={() => setTip(null)}>
          {tip}
          <div style={{ marginTop: 10, color: "#67e8f9", fontSize: 13 }}>
            Нажмите, чтобы закрыть / Yopish uchun bosing
          </div>
        </div>
      )}
    </>
  )
}
